generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   
  directUrl = env("DIRECT_URL")     
}

enum ReviewStatus {
  draft
  published
}

enum CommentStatus {
  approved
  pending
  spam
}

enum Condition {
  new
  used
  certified
}

enum LeadStatus {
  new
  contacted
  qualified
  closed
}

enum TestDriveStatus {
  pending
  confirmed
  completed
  cancelled
}

model Profile {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  password_hash String
  full_name     String?
  role          String    @default("user")
  status        String    @default("active") // active | suspended
  created_at    DateTime  @default(now())

  Review     Review[]      @relation("ProfileReviews")
  Comment    Comment[]     @relation("ProfileComments")
  likes      CommentLike[] @relation("ProfileCommentLikes")
  saved_cars SavedCar[]
  test_drives TestDrive[]
  leads      Lead[]
  preference UserPreference?

  @@map("profiles")
}

model Review {
  id             String         @id @default(uuid()) @db.Uuid
  slug           String         @unique
  title          String
  excerpt        String?
  featured_image String?
  manufacturer   String
  model          String
  year           Int
  body_style     String?
  condition      Condition      @default(used)
  content        Json
  rating         Float?
  status         ReviewStatus   @default(draft)
  featured       Boolean        @default(false)
  views          Int            @default(0)
  published_at   DateTime?
  created_by     String         @db.Uuid
  created_at     DateTime       @default(now())
  updated_at     DateTime?
  deleted_at     DateTime?

  profile        Profile        @relation(fields: [created_by], references: [id], name: "ProfileReviews")
  specs          ReviewSpec?
  gallery        ReviewGallery[]
  comments       Comment[]
  leads          Lead[]
  saved_by       SavedCar[]
  test_drives    TestDrive[]

  @@map("reviews")
}

model ReviewSpec {
  id           String  @id @default(uuid()) @db.Uuid
  review_id    String  @unique @db.Uuid
  engine       String?
  horsepower   Int?
  torque       Int?
  transmission String?
  drivetrain   String?
  fuel_type    String?
  fuel_economy String?
  top_speed    String?
  acceleration String?
  seating      Int?
  mileage      Int?
  price        Float?

  review       Review  @relation(fields: [review_id], references: [id], onDelete: Cascade)

  @@map("review_specs")
}

model ReviewGallery {
  id        String  @id @default(uuid()) @db.Uuid
  review_id String  @db.Uuid
  image_url String
  alt_text  String?
  sort_order Int?

  review    Review  @relation(fields: [review_id], references: [id], onDelete: Cascade)

  @@map("review_gallery")
}

model Comment {
  id           String        @id @default(uuid()) @db.Uuid
  review_id    String        @db.Uuid
  author_name  String
  author_email String?
  body         String
  status       CommentStatus @default(pending)
  created_by   String?       @db.Uuid
  parent_id    String?       @db.Uuid
  created_at   DateTime      @default(now())

  review       Review        @relation(fields: [review_id], references: [id], onDelete: Cascade)
  profile      Profile?      @relation(fields: [created_by], references: [id], name: "ProfileComments")
  parent       Comment?      @relation("CommentReplies", fields: [parent_id], references: [id])
  replies      Comment[]     @relation("CommentReplies")
  likes        CommentLike[]

  @@map("comments")
}

model CommentLike {
  id         String   @id @default(uuid()) @db.Uuid
  comment_id String   @db.Uuid
  profile_id String   @db.Uuid
  created_at DateTime @default(now())

  comment    Comment  @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  profile    Profile  @relation(fields: [profile_id], references: [id], name: "ProfileCommentLikes", onDelete: Cascade)

  @@unique([comment_id, profile_id])
  @@map("comment_likes")
}

model Brand {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  country      String?
  founded_year Int?
  logo_url     String?
  description  String?
  created_at   DateTime @default(now())

  @@map("brands")
}

model Lead {
  id                 String     @id @default(uuid()) @db.Uuid
  review_id          String?    @db.Uuid
  profile_id         String?    @db.Uuid
  full_name          String
  email              String
  phone              String?
  message            String?
  preferred_location String?
  status             LeadStatus @default(new)
  internal_notes     String?
  created_at         DateTime   @default(now())

  review             Review?    @relation(fields: [review_id], references: [id], onDelete: SetNull)
  profile            Profile?   @relation(fields: [profile_id], references: [id], onDelete: SetNull)

  @@map("leads")
}

model Setting {
  key        String   @id
  value      Json
  updated_at DateTime @updatedAt

  @@map("settings")
}

// A customer's "Virtual Garage" — vehicles saved for later.
model SavedCar {
  id         String   @id @default(uuid()) @db.Uuid
  profile_id String   @db.Uuid
  review_id  String   @db.Uuid
  created_at DateTime @default(now())

  profile    Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  review     Review   @relation(fields: [review_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, review_id])
  @@map("saved_cars")
}

// Test-drive appointments. profile_id is optional so anonymous visitors can book too.
model TestDrive {
  id                 String          @id @default(uuid()) @db.Uuid
  profile_id         String?         @db.Uuid
  review_id          String?         @db.Uuid
  full_name          String
  email              String
  phone              String?
  preferred_date     DateTime
  preferred_time     String?
  preferred_location String?
  message            String?
  status             TestDriveStatus @default(pending)
  created_at         DateTime        @default(now())

  profile            Profile?        @relation(fields: [profile_id], references: [id], onDelete: SetNull)
  review             Review?         @relation(fields: [review_id], references: [id], onDelete: SetNull)

  @@map("test_drives")
}

// Preference Center — one row per customer (smart-filter defaults + stock alerts opt-in).
model UserPreference {
  id              String   @id @default(uuid()) @db.Uuid
  profile_id      String   @unique @db.Uuid
  body_styles     String[]
  budget_min      Int?
  budget_max      Int?
  fuel_types      String[]
  notify_on_match Boolean  @default(false)
  updated_at      DateTime @updatedAt

  profile         Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
